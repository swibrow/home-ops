# Ansible management for plain (non-Talos) Linux hosts.
# Secrets are SOPS-encrypted with the repo age key (SOPS_AGE_KEY_FILE from the root justfile).

# Install required Ansible collections
deps:
    ansible-galaxy collection install -r requirements.yaml

# Ping the nut host over SSH
ping:
    ansible nut -m ping

# Dry-run the full nut playbook (network + NUT) and show a diff
check:
    ansible-playbook playbooks/site.yaml --check --diff

# Apply the full nut playbook (network + NUT)
deploy:
    ansible-playbook playbooks/site.yaml

# Apply only the NUT role
deploy-nut:
    ansible-playbook playbooks/nut.yaml

# Gather and print facts for the nut host
facts:
    ansible nut -m setup

# Ping the ovh-vps host over SSH
ping-ovh-vps:
    ansible ovh_vps -m ping

# Dry-run the ovh-vps playbook (fail2ban + oha) and show a diff
check-ovh-vps:
    ansible-playbook playbooks/ovh-vps.yaml --check --diff

# Apply the ovh-vps playbook (fail2ban + oha)
deploy-ovh-vps:
    ansible-playbook playbooks/ovh-vps.yaml

# Gather and print facts for the ovh-vps host
facts-ovh-vps:
    ansible ovh_vps -m setup
