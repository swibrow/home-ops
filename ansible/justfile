# Ansible management for plain (non-Talos) Linux hosts.
# Secrets are SOPS-encrypted with the repo age key (SOPS_AGE_KEY_FILE from the root justfile).

# Install required Ansible collections
deps:
    ansible-galaxy collection install -r requirements.yaml

# Ping the nut host over SSH
ping:
    ansible nut -m ping

# Dry-run the full nut playbook (network + NUT) and show a diff
check:
    ansible-playbook playbooks/site.yaml --check --diff

# Apply the full nut playbook (network + NUT)
deploy:
    ansible-playbook playbooks/site.yaml

# Apply only the NUT role
deploy-nut:
    ansible-playbook playbooks/nut.yaml

# Gather and print facts for the nut host
facts:
    ansible nut -m setup

# Ping the ovh-vps host over SSH
ping-ovh-vps:
    ansible ovh_vps -m ping

# Dry-run the ovh-vps playbook (fail2ban + oha + towonel-hub) and show a diff
check-ovh-vps:
    ansible-playbook playbooks/ovh-vps.yaml --check --diff

# Apply the ovh-vps playbook (fail2ban + oha + towonel-hub)
deploy-ovh-vps:
    ansible-playbook playbooks/ovh-vps.yaml

# Gather and print facts for the ovh-vps host
facts-ovh-vps:
    ansible ovh_vps -m setup

# Ping the proxmox-01 host over SSH
ping-proxmox-01:
    ansible proxmox_01 -m ping

# Dry-run the proxmox-01 playbook (fail2ban + repo config) and show a diff
check-proxmox-01:
    ansible-playbook playbooks/proxmox-01.yaml --check --diff

# Apply the proxmox-01 playbook (fail2ban + repo config)
deploy-proxmox-01:
    ansible-playbook playbooks/proxmox-01.yaml

# Gather and print facts for the proxmox-01 host
facts-proxmox-01:
    ansible proxmox_01 -m setup

# Migrate proxmox-01 host networking to VLAN20 (no automatic rollback - fix via
# iDRAC console if it breaks. A "connection lost" result on apply is expected.)
apply-network-proxmox-01:
    ansible-playbook playbooks/proxmox-01-network.yaml
