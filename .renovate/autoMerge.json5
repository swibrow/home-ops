{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Auto merge all patch updates",
      matchUpdateTypes: ["patch"],
      automerge: true,
      ignoreTests: false,
    },
    {
      description: "Auto merge all container updates",
      matchDatasources: ["docker"],
      automerge: true,
      matchUpdateTypes: ["digest", "patch", "minor", "pin", "pinDigest"],
      ignoreTests: false,
    },
    {
      description: "Auto merge all helm updates",
      matchDatasources: ["helm"],
      automerge: true,
      matchUpdateTypes: ["digest", "patch", "minor", "pin", "pinDigest"],
      ignoreTests: false,
    },
    {
      description: "Do NOT auto merge risky infrastructure components",
      matchPackageNames: [
        "rook-ceph",
        "rook-ceph-cluster",
        "/rook.ceph/",
        "cilium",
        "quay.io/cilium/cilium",
        "quay.io/cilium/operator-generic",
        "cloudnative-pg",
        "ghcr.io/cloudnative-pg/postgresql",
        "ghcr.io/cloudnative-pg/cloudnative-pg",
        "ghcr.io/siderolabs/installer",
        "ghcr.io/siderolabs/talosctl",
        "envoy-gateway",
        "cert-manager",
        "external-secrets",
        "volsync",
        "snapshot-controller",
        "openebs",
        "renovate-operator",
        "ghcr.io/mogenius/renovate-operator",
        "ghcr.io/renovatebot/renovate",
      ],
      automerge: false,
    },
  ],
}
