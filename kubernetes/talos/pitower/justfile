set shell := ["bash", "-euo", "pipefail", "-c"]

export SOPS_AGE_KEY_FILE := source_directory() / "../../../age.key"

import '../shared/talos.justfile'

cp_image := "factory.talos.dev/installer/de94b242ed9adec9def2581ffbf1e2d1873e42b17032771770d241dee54d7c00:v1.12.6"
cp_amd_image := "factory.talos.dev/installer/f19ad7b4a5d29151f3a59ef2d9c581cf89e77142e52f0abb5022e8f0b95ad0b9:v1.12.6"
cp_amd_mitigated_image := "factory.talos.dev/installer/e76e1f1e28537eb22f26b245f4aaf52f2007ca46eb8782ffed879c87892582f6:v1.12.6"
worker_intel_image := "factory.talos.dev/installer/97bf8e92fc6bba0f03928b859c08295d7615737b29db06a97be51dc63004e403:v1.12.6"

talosconfig := source_directory() / "clusterconfig/talosconfig"
nodes := "10.20.10.1 10.20.10.2 10.20.10.3 10.20.10.4"

# Generate talos config from secrets
config:
    sops -d ./secrets.sops.yaml > ./secrets.yaml
    talosctl gen config \
        pitower \
        https://10.20.10.0:6443 \
        --with-secrets ./secrets.yaml \
        --with-examples=true \
        --config-patch-control-plane @patches/controlplane.patch \
        --config-patch @../shared/patches/general.patch \
        --output ./clusterconfig \
        --force

# Patch machine configs for all nodes
[working-directory: 'clusterconfig']
patch:
    talosctl machineconfig patch ./controlplane.yaml --patch @../patches/nodes/worker-01.patch --output worker-01.yaml
    talosctl machineconfig patch ./controlplane.yaml --patch @../patches/nodes/worker-02.patch --output worker-02.yaml
    talosctl machineconfig patch ./controlplane.yaml --patch @../patches/nodes/worker-03.patch --output worker-03.yaml
    talosctl machineconfig patch ./worker.yaml --patch @../patches/nodes/worker-04.patch --output worker-04.yaml
    talosctl machineconfig patch ./worker.yaml --patch @../patches/nodes/worker-05.patch --output worker-05.yaml
    talosctl machineconfig patch ./worker.yaml --patch @../patches/nodes/worker-06.patch --output worker-06.yaml

# Bootstrap the Talos cluster
[working-directory: 'clusterconfig']
bootstrap:
    talosctl bootstrap --talosconfig ./talosconfig --nodes 10.20.10.1
    talosctl kubeconfig --talosconfig ./talosconfig --nodes 10.20.10.0

# Apply configs to all control plane nodes
[working-directory: 'clusterconfig']
apply-controlplanes:
    talosctl apply-config --talosconfig {{ talosconfig }} --endpoints 10.20.10.1 --nodes 10.20.10.1 --file ./worker-01.yaml
    talosctl apply-config --talosconfig {{ talosconfig }} --endpoints 10.20.10.2 --nodes 10.20.10.2 --file ./worker-02.yaml
    talosctl apply-config --talosconfig {{ talosconfig }} --endpoints 10.20.10.3 --nodes 10.20.10.3 --file ./worker-03.yaml

# Apply configs to all worker nodes
[working-directory: 'clusterconfig']
apply-workers:
    talosctl apply-config --talosconfig {{ talosconfig }} --nodes 10.20.10.4 --file ./worker-04.yaml

# Reboot control plane nodes sequentially
reboot-controlplanes:
    #!/usr/bin/env bash
    set -euo pipefail
    for i in 1 2 3; do
        talosctl --talosconfig {{ talosconfig }} reboot --endpoints "10.20.10.${i}" --nodes "10.20.10.${i}" --wait
    done

# Reboot worker nodes sequentially
reboot-workers:
    #!/usr/bin/env bash
    set -euo pipefail
    for i in 4; do
        talosctl --talosconfig {{ talosconfig }} reboot --nodes "10.20.10.${i}" --wait
    done

# Reset a Talos node by last octet (e.g. just reset 04)
reset suffix:
    talosctl --talosconfig {{ talosconfig }} reset \
        --system-labels-to-wipe=EPHEMERAL \
        --system-labels-to-wipe=META \
        --reboot \
        --graceful=false \
        -n 192.168.0.2{{ suffix }}

# Upgrade a single node by name (e.g. just upgrade worker-01)
upgrade name:
    #!/usr/bin/env bash
    set -euo pipefail
    ip=$(talosctl --talosconfig {{ talosconfig }} --endpoints 10.20.10.0 --nodes 10.20.10.0 get members -o json | jq -rs --arg h "{{ name }}" '[.[] | select(.spec.hostname == $h) | .spec.addresses[0]][0]')
    case "{{ name }}" in
        worker-01)                     image="{{ cp_amd_mitigated_image }}" ;;
        worker-02|worker-03)           image="{{ cp_amd_image }}" ;;
        worker-04|worker-05|worker-06) image="{{ worker_intel_image }}" ;;
        *)                             image="{{ cp_image }}" ;;
    esac
    echo "Upgrading {{ name }} (${ip}) with ${image}"
    talosctl --talosconfig {{ talosconfig }} --endpoints "${ip}" upgrade \
        --image "${image}" \
        --nodes "${ip}" \
        --preserve \
        --wait

# Upgrade control plane nodes (ARM)
upgrade-controlplanes:
    #!/usr/bin/env bash
    set -euo pipefail
    for i in 1 2 3; do
        talosctl --talosconfig {{ talosconfig }} upgrade \
            --image {{ cp_image }} \
            --nodes "10.20.10.${i}" \
            --preserve \
            --wait
    done

# Upgrade control plane nodes (AMD)
upgrade-controlplanes-amd:
    #!/usr/bin/env bash
    set -euo pipefail
    for i in 3; do
        talosctl --talosconfig {{ talosconfig }} upgrade \
            --image {{ cp_amd_image }} \
            --nodes "10.20.10.${i}" \
            --preserve \
            --wait
    done

# Upgrade Intel worker nodes
upgrade-workers-intel:
    #!/usr/bin/env bash
    set -euo pipefail
    for i in 4; do
        talosctl --talosconfig {{ talosconfig }} upgrade \
            --image {{ worker_intel_image }} \
            --nodes "10.20.10.${i}" \
            --preserve \
            --wait
    done

# Print Talos factory image IDs from extension files
[working-directory: '../shared/extensions']
image-id:
    #!/usr/bin/env bash
    set -euo pipefail
    for f in amd.yaml amd-mitigations.yaml intel.yaml rpi-poe.yaml; do
        name="${f%.yaml}"
        id=$(curl -sX POST --data-binary "@${f}" https://factory.talos.dev/schematics | jq -r .id)
        echo "${name}: ${id}"
    done
