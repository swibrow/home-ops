---
machine:
  nodeLabels:
    feature.node.kubernetes.io/amd-gpu: "true"
  install:
    image: factory.talos.dev/installer/86e7fd87fc2c25ce2adb947bbf084f78d473e206487a2eb7df5fc157539bc999:v1.12.6
  kubelet:
    nodeIP:
      validSubnets:
        - 10.20.0.0/16
    extraArgs:
      register-with-taints: "dedicated=storage:NoSchedule"
  network:
    interfaces:
      - deviceSelector:
          physical: true
          hardwareAddr: 1c:83:41:40:88:41
        vlans:
          - vlanId: 20
            dhcp: true
  logging:
    destinations:
      - endpoint: tcp://data:9898
        format: json_lines
---
apiVersion: v1alpha1
kind: HostnameConfig
auto: off
hostname: worker-01
