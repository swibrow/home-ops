---
machine:
  install:
    image: factory.talos.dev/installer/f04c5385947c2b476d602755abc281a9f89ffdd4bb0325206e9ec5b656a2aeb9:v1.12.6
  kubelet:
    nodeIP:
      validSubnets:
        - 10.20.0.0/16
    extraArgs:
      register-with-taints: "dedicated=storage:NoSchedule"
  network:
    interfaces:
      - deviceSelector:
          physical: true
          hardwareAddr: 1c:83:41:40:88:41
        vlans:
          - vlanId: 20
            dhcp: true
            vip:
              ip: 10.20.10.0
  logging:
    destinations:
      - endpoint: tcp://data:9898
        format: json_lines
