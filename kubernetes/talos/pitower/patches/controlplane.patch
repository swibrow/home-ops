cluster:
  allowSchedulingOnControlPlanes: true
  coreDNS:
      disabled: true
  # Expose etcd metrics on :2381 (http) so kube-prometheus-stack's kubeEtcd
  # ServiceMonitor can scrape them. Without this etcd serves metrics only on the
  # cert-guarded client port and the etcd dashboard stays empty.
  etcd:
    extraArgs:
      listen-metrics-urls: http://0.0.0.0:2381
  # Bind controller-manager / scheduler metrics to all interfaces (default is
  # 127.0.0.1), otherwise the kube-prometheus-stack ServiceMonitors get
  # connection-refused (up==0) and those dashboards are empty.
  controllerManager:
    extraArgs:
      bind-address: 0.0.0.0
  scheduler:
    extraArgs:
      bind-address: 0.0.0.0
  apiServer:
    certSANs:
      # - k8s.pitower.internal
      - 10.20.10.0
      - 127.0.0.1
    extraArgs:
        oidc-issuer-url: https://auth.wibrow.dev
        oidc-client-id: headlamp
        oidc-username-claim: email
        oidc-username-prefix: "oidc:"
        oidc-groups-claim: groups
        oidc-groups-prefix: "oidc:"
        service-account-issuer: https://raw.githubusercontent.com/swibrow/home-ops/main/pitower/kubernetes
        service-account-jwks-uri: https://k8s.pitower.internal:6443/openid/v1/jwks
