      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "sum(rate(cilium_operator_errors_warnings_total[5m])) by (level)",
          "legendFormat": "{{level}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Errors & warnings rate by level",
      "type": "timeseries"
