      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "cilium_operator_process_resident_memory_bytes{io_cilium_app=\"operator\"}",
          "legendFormat": "{{pod}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Resident memory per pod",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "description": "Rate of logged errors and warnings, by level. Sustained non-zero ERROR is worth investigating.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
