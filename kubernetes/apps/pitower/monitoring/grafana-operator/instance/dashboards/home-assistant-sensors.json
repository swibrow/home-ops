{
  "uid": "ha-sensors",
  "title": "Home Assistant - Sensors",
  "tags": ["home-assistant"],
  "timezone": "Europe/Zurich",
  "schemaVersion": 38,
  "editable": true,
  "time": {"from": "now-24h", "to": "now"},
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "entity",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "victoriametrics"},
        "query": {"query": "label_values({source=\"home-assistant\", __name__=~\".+_value\"}, friendly_name)", "refId": "StandardVariableQuery"},
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "sort": 1
      }
    ]
  },
  "annotations": {"list": []},
  "panels": [
    {
      "type": "timeseries",
      "id": 1,
      "title": "Temperature sensors",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "celsius", "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "min", "max"]}},
      "targets": [{"expr": "°C_value{source=\"home-assistant\"}", "refId": "A", "legendFormat": "{{friendly_name}}"}]
    },
    {
      "type": "timeseries",
      "id": 2,
      "title": "Power (W)",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "watt", "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}},
      "targets": [{"expr": "W_value{source=\"home-assistant\"}", "refId": "A", "legendFormat": "{{friendly_name}}"}]
    },
    {
      "type": "timeseries",
      "id": 3,
      "title": "Energy (kWh)",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 10},
      "fieldConfig": {"defaults": {"unit": "kwatth", "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}},
      "targets": [{"expr": "kWh_value{source=\"home-assistant\"}", "refId": "A", "legendFormat": "{{friendly_name}}"}]
    },
    {
      "type": "timeseries",
      "id": 4,
      "title": "Current (A)",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 10},
      "fieldConfig": {"defaults": {"unit": "amp", "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}},
      "targets": [{"expr": "A_value{source=\"home-assistant\"}", "refId": "A", "legendFormat": "{{friendly_name}}"}]
    },
    {
      "type": "table",
      "id": 5,
      "title": "All numeric sensors (last value)",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 20},
      "fieldConfig": {"defaults": {}},
      "options": {"showHeader": true},
      "targets": [{"expr": "last_over_time({source=\"home-assistant\", __name__=~\".+_value\", friendly_name=~\"$entity\"}[1h])", "refId": "A", "instant": true, "format": "table"}]
    }
  ]
}
