set shell := ["bash", "-euo", "pipefail", "-c"]

export TERRAFORM_WORKING_DIR := "terraform"

# The shared S3 state backend needs the wibrow-tf profile (wraps wibrow's
# login session via credential_process - see terraform/proxmox/README.md).
# An explicitly set AWS_PROFILE still wins.
export AWS_PROFILE := env_var_or_default("AWS_PROFILE", "wibrow-tf")

# Run Terraform init and plan for all modules
all:
    #!/usr/bin/env bash
    set -euo pipefail
    for dir in $(find "${TERRAFORM_WORKING_DIR}" -mindepth 1 -maxdepth 1 -type d); do
        echo "Working on ${ENVIRONMENT} in ${dir}"
        cd "${dir}"
        terraform init
        terraform plan
        terraform apply
        cd -
    done

# Run Terraform init for a stack
init environment stack:
    #!/usr/bin/env bash
    set -euo pipefail
    set -a
    source .config/.env.{{ environment }}
    set +a
    cd {{ TERRAFORM_WORKING_DIR }}/{{ stack }}
    echo "Working on {{ environment }} in {{ stack }}"
    echo "Working on ${TF_WORKSPACE}"

# Run Terraform init and plan for a specific environment
environment environment:
    #!/usr/bin/env bash
    set -euo pipefail
    for dir in $(find "${TERRAFORM_WORKING_DIR}" -mindepth 1 -maxdepth 1 -type d -name "{{ environment }}"); do
        echo "Working on {{ environment }} in ${dir}"
    done

# Init the proxmox stack (Proxmox API credentials come from mise.toml's [env] - PROXMOX_VE_*)
init-proxmox:
    terraform -chdir={{ justfile_directory() }}/{{ TERRAFORM_WORKING_DIR }}/proxmox init

# Plan the proxmox stack
plan-proxmox:
    terraform -chdir={{ justfile_directory() }}/{{ TERRAFORM_WORKING_DIR }}/proxmox plan

# Apply the proxmox stack
apply-proxmox:
    terraform -chdir={{ justfile_directory() }}/{{ TERRAFORM_WORKING_DIR }}/proxmox apply
